# Backend secrets — copy to backend/.env and fill in for local dev.
# Backend refuses to start without ANTHROPIC_API_KEY.
# DEEPGRAM_API_KEY only required from Phase 2 onward.

ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Optional: log verbosity. info|debug|warning. default info.
INSTINCT_LOG_LEVEL=info

# Optional: per-session cost ceiling in USD. default 5.0.
INSTINCT_COST_CEILING_USD=5.0
