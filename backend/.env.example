# Backend secrets — copy to backend/.env and fill in for local dev.
# Backend refuses to start without NVIDIA_API_KEY (v1 default provider).
# ANTHROPIC_API_KEY is optional (only used by legacy v0 paths if any).
# DEEPGRAM_API_KEY only relevant if not using nvidia/nemotron-asr-streaming.

NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# Optional: log verbosity. info|debug|warning. default info.
INSTINCT_LOG_LEVEL=info

# Optional: per-session cost ceiling in USD. default 5.0.
INSTINCT_COST_CEILING_USD=5.0

# Optional: per-agent NVIDIA model overrides. Defaults in providers/nvidia.py.
# INSTINCT_TAGGER_MODEL=google/gemma-3n-e2b-it
# INSTINCT_BUILDER_MODEL=qwen/qwen3-coder-480b-a35b-instruct
# INSTINCT_CRITIC_MODEL=moonshotai/kimi-k2-thinking
# INSTINCT_CLARIFIER_MODEL=z-ai/glm-4.7
# INSTINCT_SYNTHESIS_MODEL=deepseek-ai/deepseek-v3.2
# INSTINCT_VISION_OCR_MODEL=nvidia/nemotron-ocr-v1
# INSTINCT_VISION_LAYOUT_MODEL=nvidia/nemotron-page-elements-v3
# INSTINCT_VISION_INTERP_MODEL=mistralai/mistral-large-3-675b-instruct-2512
# INSTINCT_TRANSCRIPTION_MODEL=nvidia/nemotron-asr-streaming
# INSTINCT_TEXT_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
# INSTINCT_CODE_EMBED_MODEL=nvidia/nv-embedcode-7b-v1
# INSTINCT_PII_MODEL=nvidia/gliner-pii

# Optional: webhook for endpoint health alerts (POSTed JSON on red status).
# INSTINCT_HEALTH_WEBHOOK_URL=
